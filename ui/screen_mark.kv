#:kivy 2.0
<MarkScreen>:
    BoxLayout:
        orientation: "vertical"
        padding: 12
        spacing: 6
        Label:
            text: "Отметить занятие"
            font_size: 20
            size_hint_y: None
            height: 34
        Label:
            text: root.message
            size_hint_y: None
            height: 26
        BoxLayout:
            size_hint_y: None
            height: 40
            Spinner:
                text: "Группа"
                values: root.groups
                on_text: root.select_group(self.text)
            Spinner:
                text: "Предмет"
                values: root.subjects
                on_text: root.select_subject(self.text)
        BoxLayout:
            size_hint_y: None
            height: 40
            TextInput:
                id: mark_date
                hint_text: "Дата YYYY-MM-DD (пусто=сегодня)"
            TextInput:
                id: mark_time
                hint_text: "HH:MM (пусто=сейчас)"
        Label:
            text: "Занятие было проведено?"
            size_hint_y: None
            height: 26
        BoxLayout:
            size_hint_y: None
            height: 42
            Button:
                text: "Да"
                background_color: 0.2, 0.7, 0.3, 1
                on_release: root.ask_conducted(mark_date.text, mark_time.text, True)
            Button:
                text: "Нет"
                background_color: 0.85, 0.3, 0.3, 1
                on_release: root.ask_conducted(mark_date.text, mark_time.text, False)
        ScrollView:
            BoxLayout:
                id: students_box
                orientation: "vertical"
                size_hint_y: None
                height: self.minimum_height
                spacing: 4
        BoxLayout:
            size_hint_y: None
            height: 44
            Button:
                text: "Сохранить"
                on_release: root.save()
            Button:
                text: "Назад"
                on_release: root.manager.current = "home"
